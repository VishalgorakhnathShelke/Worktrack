WORKTRACE_ENV=development
WORKTRACE_DATABASE_URL=sqlite:///./data/worktrace.sqlite3
WORKTRACE_TENANT_ID=00000000-0000-0000-0000-000000000001
WORKTRACE_API_TOKEN=replace-with-a-long-random-token
WORKTRACE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
WORKTRACE_ALLOWED_DOMAINS=example.test
WORKTRACE_AI_PROVIDER=local
WORKTRACE_EXTERNAL_AI_ENABLED=false
WORKTRACE_EXTERNAL_AI_APPROVAL_REQUIRED=true
WORKTRACE_OPENAI_API_KEY=
WORKTRACE_ANTHROPIC_API_KEY=
