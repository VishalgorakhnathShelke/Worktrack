{
  "manifest_version": 3,
  "name": "WorkTrace Recorder",
  "version": "0.1.0",
  "description": "Durably uploads WorkTrace recording chunks.",
  "permissions": ["activeTab", "alarms", "storage", "unlimitedStorage"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.mjs",
    "type": "module"
  },
  "action": {
    "default_title": "WorkTrace Recorder"
  }
}
